#!/usr/bin/env bash
# Manage the devcontainer egress proxy stack.
# Works on macOS and Linux (any system with Docker + Bash 3.2+).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
COMPOSE_FILE="$REPO_DIR/compose.yml"
DEFAULTS_DIR="$REPO_DIR/defaults"

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/devcontainer-egress"
ALLOWLIST="$CONFIG_DIR/allowlist.txt"

PROXY_HOST="squid"
PROXY_PORT="3128"
NETWORK="egress-agents"
CONTAINER="egress-squid"

SKILL_NAME="devcontainer-egress"
SKILL_SRC="$REPO_DIR/agent/skills/$SKILL_NAME"
CLAUDE_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
SKILL_DEST="$CLAUDE_DIR/skills/$SKILL_NAME"

usage() {
  cat <<EOF
Usage: egress <command>

Commands:
  up        Start the egress proxy (idempotent; bootstraps allowlist on first run)
  down      Stop and remove the egress proxy and its networks
  restart   Restart Squid (full container restart)
  reload    Reload Squid config without dropping connections (after editing allowlist)
  status    Show the proxy's status
  logs      Tail the Squid access log
  test      Run allow / deny / bypass smoke tests
  add       Append one or more domains to the allowlist and reload
  edit      Open the allowlist in \$EDITOR
  config    Print the path to the user allowlist
  install-skill    Symlink the Claude Code skill into \$CLAUDE_CONFIG_DIR/skills/
  uninstall-skill  Remove that symlink
  help      Show this help

User allowlist: $ALLOWLIST

Any devcontainer or 'docker run' joins this proxy with:
  --network=$NETWORK -e HTTPS_PROXY=http://$PROXY_HOST:$PROXY_PORT
EOF
}

require_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "error: docker not found on PATH" >&2
    exit 1
  fi
}

bootstrap_allowlist() {
  if [ ! -f "$ALLOWLIST" ]; then
    mkdir -p "$CONFIG_DIR"
    cp "$DEFAULTS_DIR/allowlist.txt" "$ALLOWLIST"
    echo "Created allowlist at $ALLOWLIST (from defaults)."
    echo "Edit with: egress edit"
  fi
}

# Compose interpolates ${HOME} for the bind mount. Fail fast if the resolved
# allowlist path doesn't exist (compose otherwise creates it as an empty dir).
require_allowlist() {
  if [ ! -f "$ALLOWLIST" ]; then
    echo "error: allowlist not found at $ALLOWLIST" >&2
    echo "       run 'egress up' to bootstrap it from defaults." >&2
    exit 1
  fi
}

cmd_up() {
  bootstrap_allowlist
  docker compose -f "$COMPOSE_FILE" up -d
}

cmd_down()    { docker compose -f "$COMPOSE_FILE" down; }
cmd_restart() { require_allowlist; docker compose -f "$COMPOSE_FILE" restart squid; }
cmd_reload()  { docker exec "$CONTAINER" squid -k reconfigure; echo "reloaded"; }
cmd_status()  { docker compose -f "$COMPOSE_FILE" ps; }
cmd_logs()    { docker exec "$CONTAINER" tail -f /var/log/squid/access.log; }
cmd_edit()    { bootstrap_allowlist; "${EDITOR:-vi}" "$ALLOWLIST"; }
cmd_config()  { echo "$ALLOWLIST"; }

# True if $SKILL_DEST is a symlink whose canonical target equals $SKILL_SRC's
# canonical path. Handles relative vs absolute symlinks by resolving both.
_skill_dest_points_at_src() {
  [ -L "$SKILL_DEST" ] || return 1
  local resolved src_resolved
  resolved="$(cd "$SKILL_DEST" 2>/dev/null && pwd -P)" || return 1
  src_resolved="$(cd "$SKILL_SRC" 2>/dev/null && pwd -P)" || return 1
  [ "$resolved" = "$src_resolved" ]
}

cmd_install_skill() {
  if [ ! -d "$SKILL_SRC" ]; then
    echo "error: skill source not found at $SKILL_SRC" >&2
    exit 1
  fi

  mkdir -p "$(dirname "$SKILL_DEST")"

  if [ -L "$SKILL_DEST" ]; then
    if _skill_dest_points_at_src; then
      echo "already installed: $SKILL_DEST -> $SKILL_SRC"
      return 0
    fi
    local current
    current="$(readlink "$SKILL_DEST")"
    echo "error: $SKILL_DEST is a symlink to '$current'." >&2
    echo "       remove it first if you want to install ours:" >&2
    echo "         rm '$SKILL_DEST'" >&2
    exit 1
  elif [ -e "$SKILL_DEST" ]; then
    echo "error: $SKILL_DEST already exists and is not a symlink." >&2
    echo "       remove it first if you want to install." >&2
    exit 1
  fi

  ln -s "$SKILL_SRC" "$SKILL_DEST"
  echo "installed: $SKILL_DEST -> $SKILL_SRC"
}

cmd_uninstall_skill() {
  if [ ! -L "$SKILL_DEST" ] && [ ! -e "$SKILL_DEST" ]; then
    echo "not installed: $SKILL_DEST"
    return 0
  fi

  if [ ! -L "$SKILL_DEST" ]; then
    echo "error: $SKILL_DEST exists but is not a symlink; refusing to remove." >&2
    exit 1
  fi

  if ! _skill_dest_points_at_src; then
    local current
    current="$(readlink "$SKILL_DEST")"
    echo "error: $SKILL_DEST is a symlink to '$current' (not ours)." >&2
    echo "       remove it manually if you really want to." >&2
    exit 1
  fi

  rm "$SKILL_DEST"
  echo "removed: $SKILL_DEST"
}

cmd_add() {
  if [ $# -eq 0 ]; then
    cat >&2 <<EOF
usage: egress add <domain> [<domain> ...]

  Each <domain> is appended to the allowlist with a leading dot
  (subdomain match) if it doesn't already have one. Existing entries
  are skipped. Squid is reloaded automatically if it's running.

  Examples:
    egress add slack.com
    egress add linear.app notion.com
    egress add api.internal.example   # exact host: '.api.internal.example'
EOF
    exit 1
  fi

  bootstrap_allowlist

  local added_any=0 raw domain
  for raw in "$@"; do
    domain="$raw"
    domain="${domain#http://}"
    domain="${domain#https://}"
    domain="${domain%%/*}"
    domain="${domain#\*.}"

    if ! echo "$domain" | grep -Eq '^[a-zA-Z0-9][a-zA-Z0-9.-]*\.[a-zA-Z0-9.-]*[a-zA-Z0-9]$'; then
      echo "skipped: '$raw' doesn't look like a hostname" >&2
      continue
    fi

    case "$domain" in
      .*) ;;
      *) domain=".$domain" ;;
    esac

    if grep -Fxq "$domain" "$ALLOWLIST"; then
      echo "already present: $domain"
      continue
    fi

    echo "$domain" >> "$ALLOWLIST"
    echo "added: $domain"
    added_any=1
  done

  if [ "$added_any" -eq 1 ]; then
    if docker ps --format '{{.Names}}' | grep -q "^${CONTAINER}$"; then
      cmd_reload
    else
      echo "(Squid not running; changes apply on 'egress up')"
    fi
  fi
}

cmd_test() {
  local allowed_host="${1:-api.anthropic.com}"
  local denied_host="${2:-example.com}"

  echo "=== allowed ($allowed_host) ==="
  docker run --rm --network "$NETWORK" \
    -e HTTPS_PROXY="http://$PROXY_HOST:$PROXY_PORT" \
    curlimages/curl -sI "https://$allowed_host" \
      -o /dev/null -w 'HTTP %{http_code}\n' || true

  echo "=== denied ($denied_host) ==="
  docker run --rm --network "$NETWORK" \
    -e HTTPS_PROXY="http://$PROXY_HOST:$PROXY_PORT" \
    curlimages/curl -sI --max-time 4 "https://$denied_host" \
      -o /dev/null -w 'HTTP %{http_code}\n' 2>/dev/null || echo "(refused)"

  echo "=== bypass attempt (raw IP, no proxy) ==="
  docker run --rm --network "$NETWORK" \
    curlimages/curl -sS --max-time 3 https://1.1.1.1 -o /dev/null 2>&1 | tail -1 || true
}

require_docker
case "${1:-help}" in
  up)              cmd_up ;;
  down)            cmd_down ;;
  restart)         cmd_restart ;;
  reload)          cmd_reload ;;
  status|ps)       cmd_status ;;
  logs)            cmd_logs ;;
  test)            shift; cmd_test "$@" ;;
  add)             shift; cmd_add "$@" ;;
  edit)            cmd_edit ;;
  config)          cmd_config ;;
  install-skill)   cmd_install_skill ;;
  uninstall-skill) cmd_uninstall_skill ;;
  -h|--help|help)  usage ;;
  *) echo "unknown command: $1" >&2; usage >&2; exit 1 ;;
esac
